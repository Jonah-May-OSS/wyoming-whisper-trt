#!/usr/bin/env python3
"""Lint the package and tests with ruff, black, isort, and mypy in the venv."""

import subprocess

from _common import MODULE_DIR, TESTS_DIR, venv_python

_LINT_DIRS = [MODULE_DIR, TESTS_DIR]
python = venv_python()

# Run ruff for fast linting and formatting checks
subprocess.check_call([python, "-m", "ruff", "check", *_LINT_DIRS])
subprocess.check_call([python, "-m", "ruff", "format", "--check", *_LINT_DIRS])

# Run traditional linters for additional checks
subprocess.check_call([python, "-m", "black", *_LINT_DIRS, "--check"])
subprocess.check_call([python, "-m", "isort", *_LINT_DIRS, "--check"])
subprocess.check_call([python, "-m", "mypy", *_LINT_DIRS])
