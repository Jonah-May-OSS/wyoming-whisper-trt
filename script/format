#!/usr/bin/env python3
"""Auto-format the package and tests with ruff, black, and isort in the venv."""

import subprocess

from _common import MODULE_DIR, TESTS_DIR, venv_python

_FORMAT_DIRS = [MODULE_DIR, TESTS_DIR]
python = venv_python()

# Run ruff for fast auto-fixes and formatting
subprocess.check_call([python, "-m", "ruff", "check", "--fix", *_FORMAT_DIRS])
subprocess.check_call([python, "-m", "ruff", "format", *_FORMAT_DIRS])

# Run traditional formatters
subprocess.check_call([python, "-m", "black", *_FORMAT_DIRS])
subprocess.check_call([python, "-m", "isort", *_FORMAT_DIRS])
